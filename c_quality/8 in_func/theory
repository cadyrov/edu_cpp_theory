__attribute__((noinline)) uint8_t ClampFloatVal(float v) {
    return static_cast<uint8_t>(std::max(0.f, std::min(255.f, v + .5f)));
}

__attribute__((noinline)) uint8_t ClampFloatRef(const float& v) {
    return static_cast<uint8_t>(std::max(0.f, std::min(255.f, v + .5f)));
} 
