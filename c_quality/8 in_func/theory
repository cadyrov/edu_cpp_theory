Константная ссылка
Константная ссылка — по правилу поглощения ссылок обычная ссылка всегда побеждает:

#include <utility>

using namespace std;

using IntRef = int&;
using IntRvalRef = int&&;

// ссылка на rvalue-ссылку - обычная ссылка
static_assert(is_same_v<IntRvalRef&, int&>);

// rvalue-ссылка на ссылку - всё равно обычная ссылка
static_assert(is_same_v<IntRef&&, int&>);

// даже константная rvalue-ссылка на ссылку - обычная ссылка
static_assert(is_same_v<const IntRef&&, int&>); 

class Cls {
public:
    template <typename T>
    int F(unique_ptr<T>&& x);
}; 
